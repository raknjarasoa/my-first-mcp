PORT=3000

# On-premise LLM — any OpenAI-compatible endpoint
# Examples: Qwen3-Coder, Mistral Medium, GPT on-prem
LLM_BASE_URL=https://llm.internal/v1
LLM_MODEL=qwen3-coder

# LLM_API_KEY is provided per user at session init (nominative).
# This fallback is only for local dev without session auth.
LLM_API_KEY_FALLBACK=

# Compute API base URL
COMPUTE_BASE_URL=https://compute.internal

# Session TTL in milliseconds (default: 8 hours)
SESSION_TTL_MS=28800000

# Workspace metadata cache TTL in milliseconds (default: 30 minutes)
METADATA_CACHE_TTL_MS=1800000

# mTLS (optional — set all three paths to enable, leave empty to use plain HTTPS)
MTLS_CERT_PATH=
MTLS_KEY_PATH=
MTLS_CA_PATH=
